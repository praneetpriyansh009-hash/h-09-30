generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── CORE ENTITIES ────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?   @unique
  passwordHash  String?
  role          String    @default("USER") // Changed to String for SQLite enum support if needed
  profilePicUrl String?
  city          String?
  state         String?
  isVerified    Boolean   @default(false)
  deletedAt     DateTime? // soft delete for GDPR
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendorProfile        VendorProfile?
  bundles              PartyBundle[]
  bundleCollaborations BundleCollaborator[]
  bookings             Booking[]
  reviews              Review[]
  notifications        Notification[]
  // A User can be a vendor internally; ChatMessage senders are always Users.
  // VendorProfile.userId links the vendor's user account.
  sentMessages         ChatMessage[]        @relation("SentMessages")
}

model Theme {
  id            String  @id @default(uuid())
  name          String
  slug          String  @unique
  description   String
  coverImageUrl String
  moodKeywords  String // JSON string since SQLite doesn't support String[]
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  vendors VendorTheme[]
  bundles PartyBundle[]
}

model Category {
  id                    String @id @default(uuid())
  name                  String
  slug                  String @unique
  iconUrl               String
  description           String
  defaultCommissionRate Float

  vendorCategories VendorCategory[]
  services         VendorService[]
}

model VendorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  businessName String
  description  String
  gstin        String?
  city         String
  state        String
  pincode      String
  addressLine  String
  lat          Float?
  lng          Float?

  commissionRate     Float // set by admin; vendor cannot edit
  isFeatured         Boolean @default(false) // set by admin only
  isApproved         Boolean @default(false)
  averageRating      Float   @default(0)
  totalBookings      Int     @default(0)
  bankAccountDetails String? // JSON string for AES-256 encrypted blob

  responseTimeHours      Float?
  minBookingAdvanceHours Int      @default(24)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  categories   VendorCategory[]
  themes       VendorTheme[]
  services     VendorService[]
  availability VendorAvailability[]
  bookings     Booking[]
  payouts      VendorPayout[]
  reviews      Review[]
  chatMessages ChatMessage[]        @relation("VendorMessages")
}

model VendorCategory {
  vendorId   String
  categoryId String
  isPrimary  Boolean       @default(false)
  vendor     VendorProfile @relation(fields: [vendorId], references: [id])
  category   Category      @relation(fields: [categoryId], references: [id])

  @@id([vendorId, categoryId])
}

model VendorTheme {
  vendorId String
  themeId  String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  theme    Theme         @relation(fields: [themeId], references: [id])

  @@id([vendorId, themeId])
}

model VendorService {
  id         String        @id @default(uuid())
  vendorId   String
  vendor     VendorProfile @relation(fields: [vendorId], references: [id])
  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])

  title       String
  description String
  basePrice   Float
  priceUnit   String // String instead of ENUM for SQLite
  maxCapacity Int?
  photos      String // JSON string for Cloudflare R2 URLs
  isActive    Boolean @default(true)
  tags        String // JSON string for tags

  // Immutable price audit trail. On every price change, append {price, changedAt}.
  priceHistory String @default("[]") // JSON string

  bundleItems BundleItem[]
  bookings    Booking[]
}

// Weekly recurring availability + specific date overrides.
// Vendors set a weeklyTemplate once; specific date exceptions override it.
model VendorAvailability {
  id       String        @id @default(uuid())
  vendorId String
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])

  isTemplate Boolean   @default(false)
  dayOfWeek  Int? // 0=Sun…6=Sat; null if not a template row
  date       DateTime? // specific date override; null if template row
  isBlocked  Boolean   @default(false)
  // Example slot: [{"from":"18:00","to":"22:00","isBooked":false}]
  slots      String    @default("[]") // JSON string
}

// ─── BUNDLE (PARTY PLAN / CART) ────────────────────────────

model PartyBundle {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title        String // e.g. "Aryan & Priya's Date Night"
  occasionType String // String for SQLite ENUM
  themeId      String?
  theme        Theme?   @relation(fields: [themeId], references: [id])
  partyDate    DateTime
  partyTime    String? // "19:30" — stored as HH:mm string (IST context)
  guestCount   Int
  budgetMax    Float?
  city         String
  status       String   @default("DRAFT") // String for SQLite ENUM
  totalAmount  Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         BundleItem[]
  addOns        BundleAddOn[]
  collaborators BundleCollaborator[]
  payment       Payment?
  messages      ChatMessage[]
}

model BundleItem {
  id              String        @id @default(uuid())
  bundleId        String
  bundle          PartyBundle   @relation(fields: [bundleId], references: [id])
  vendorServiceId String
  vendorService   VendorService @relation(fields: [vendorServiceId], references: [id])

  quantity      Int     @default(1)
  customNote    String?
  unitPrice     Float // snapshot at checkout time
  // Full snapshot of service details at checkout time. Immutable after checkout.
  // Shape: { title, description, vendorName, basePrice, priceUnit, photos[0] }
  priceSnapshot String // JSON string
  itemStatus    String  @default("PENDING") // String for SQLite ENUM

  booking Booking?
}

model BundleCollaborator {
  id          String      @id @default(uuid())
  bundleId    String
  bundle      PartyBundle @relation(fields: [bundleId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  email       String? // invite by email before account creation
  role        String      @default("VIEWER") // String for SQLite ENUM
  inviteToken String?     @unique
  acceptedAt  DateTime?
  createdAt   DateTime    @default(now())
}

// ─── ADD-ON CATALOG ────────────────────────────────────────

model AddOnCatalogItem {
  id                String  @id @default(uuid())
  name              String
  description       String
  imageUrl          String
  price             Float
  // "floral" | "chocolate" | "candles" | "balloons" | "cake" | "photography" | "extras"
  categorySlug      String
  isVendorFulfilled Boolean @default(true)
  vendorId          String? // assigned vendor (if vendor-fulfilled)
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)

  bundleAddOns BundleAddOn[]
}

model BundleAddOn {
  id          String           @id @default(uuid())
  bundleId    String
  bundle      PartyBundle      @relation(fields: [bundleId], references: [id])
  addOnItemId String
  addOnItem   AddOnCatalogItem @relation(fields: [addOnItemId], references: [id])
  quantity    Int              @default(1)
  totalPrice  Float // quantity × addOnItem.price at time of adding
  customNote  String?
}

// ─── BOOKING ───────────────────────────────────────────────

model Booking {
  id           String        @id @default(uuid())
  bundleId     String?
  bundleItemId String?       @unique
  bundleItem   BundleItem?   @relation(fields: [bundleItemId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  vendorId     String
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
  serviceId    String
  service      VendorService @relation(fields: [serviceId], references: [id])

  bookingDate      DateTime
  startTime        String // "19:00"
  endTime          String? // "22:00"
  guestCount       Int
  totalAmount      Float
  commissionAmount Float
  vendorEarning    Float

  status      String   @default("REQUESTED") // String for SQLite ENUM
  vendorNotes String?
  userNotes   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payout VendorPayout?
  review Review?
}

// ─── PAYMENTS ──────────────────────────────────────────────

model Payment {
  id       String       @id @default(uuid())
  bundleId String?      @unique
  bundle   PartyBundle? @relation(fields: [bundleId], references: [id])

  razorpayOrderId   String    @unique
  razorpayPaymentId String?
  amount            Float
  currency          String    @default("INR")
  status            String    @default("PENDING") // String for SQLite ENUM
  refundAmount      Float?
  refundReason      String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  splits PaymentSplit[]
}

// Each co-payer receives their own Razorpay payment link.
// shareToken is the URL-safe token embedded in /pay/:splitToken.
// One-time-use: after payment, mark as PAID and invalidate token server-side.
model PaymentSplit {
  id        String  @id @default(uuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  payerEmail String
  payerPhone String?
  payerName  String?
  amount     Float
  shareToken String  @unique
  status     String  @default("PENDING") // String for SQLite ENUM

  razorpayOrderId   String?
  razorpayPaymentId String?
  paidAt            DateTime?
  // Co-payer has 30 minutes from link creation to pay.
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
}

model VendorPayout {
  id        String        @id @default(uuid())
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id])

  grossAmount        Float
  commissionDeducted Float
  netPayout          Float
  status             String    @default("PENDING") // String for SQLite ENUM
  transferId         String?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())
}

// ─── COMMUNICATION ─────────────────────────────────────────

// Chat is scoped to a (bundle, vendor) pair.
// Sender is always a User. Vendors are Users with role=VENDOR.
// vendorId links to VendorProfile for vendor-side routing and notifications.
// Socket.io room key: "bundle:{bundleId}:vendor:{vendorId}"
model ChatMessage {
  id       String        @id @default(uuid())
  bundleId String
  bundle   PartyBundle   @relation(fields: [bundleId], references: [id])
  vendorId String
  vendor   VendorProfile @relation("VendorMessages", fields: [vendorId], references: [id])
  senderId String
  sender   User          @relation("SentMessages", fields: [senderId], references: [id])

  message       String
  attachmentUrl String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Review {
  id        String        @id @default(uuid())
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])

  rating          Int // 1–5, enforce CHECK constraint in migration
  reviewText      String
  vendorReply     String?
  vendorRepliedAt DateTime?
  isVisible       Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // e.g. "BOOKING_CONFIRMED", "SPLIT_PAYMENT_REMINDER", "NEW_MESSAGE"
  title     String
  body      String
  data      String? // JSON string for extra payload (e.g. {bundleId, bookingId})
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── SYSTEM ────────────────────────────────────────────────

// Stores in-progress wizard state for anonymous + authenticated users.
// Anonymous: sessionKey stored in httpOnly cookie. On login, session is merged to userId.
model WizardSession {
  id          String   @id @default(uuid())
  userId      String?
  sessionKey  String   @unique
  currentStep Int      @default(1)
  // Shape: { occasionType, themeId, city, date, time, guestCount, budgetMax,
  //          selectedVenueServiceId, addOns:[{addOnItemId, quantity}],
  //          transportServiceId, splitPayers:[{name, email, phone}] }
  data        String   @default("{}") // JSON string
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Audit trail for all admin and sensitive system actions.
// AuditLog write MUST succeed before any admin action executes.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorRole  String // String for SQLite ENUM
  action     String // "VENDOR_APPROVED" | "COMMISSION_UPDATED" | "REFUND_ISSUED" | ...
  entityType String // "VendorProfile" | "Booking" | "Payment" | ...
  entityId   String
  before     String? // JSON string
  after      String? // JSON string
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// Key-value config store for admin-adjustable platform settings.
// Keys: "CANCELLATION_POLICY", "SPLIT_EXPIRY_MINUTES", "PAYOUT_DISPUTE_DAYS", etc.
model AdminConfig {
  key   String @id
  value String // JSON string
}
